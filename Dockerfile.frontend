FROM node:18-alpine AS builder

WORKDIR /app

# 复制依赖
COPY frontend/package*.json ./
RUN npm ci

# 复制代码
COPY frontend/ .

# 构建生产版本
RUN npm run build

# 生产阶段 - 使用Nginx部署
FROM nginx:alpine

# 复制构建产物
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制Nginx配置
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
